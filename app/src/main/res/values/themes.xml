<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Main App Theme - Modern Rounded Social UI -->
    <style name="Theme.Amatyma" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Brand Color - Vibrant Red -->
        <item name="colorPrimary">@color/red_500</item>
        <item name="colorPrimaryVariant">@color/red_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/red_300</item>
        <item name="colorSecondaryVariant">@color/red_700</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Error Color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Background & Surface - Soft Social Feed Style -->
        <item name="android:colorBackground">@color/off_white</item>
        <item name="colorOnBackground">@color/gray_900</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/gray_900</item>

        <!-- Window background to prevent white flash -->
        <item name="android:windowBackground">@color/off_white</item>

        <!-- Material3 Containers -->
        <item name="colorPrimaryContainer">@color/red_300</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorSecondaryContainer">@color/gray_100</item>
        <item name="colorOnSecondaryContainer">@color/gray_900</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/red_700</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Rounded Global Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Amatyma.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Amatyma.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Amatyma.LargeComponent</item>

        <!-- Component Styles -->
        <item name="materialButtonStyle">@style/Widget.Amatyma.Button</item>
        <item name="materialCardViewStyle">@style/Widget.Amatyma.Card</item>
        <item name="textInputStyle">@style/Widget.Amatyma.TextInputLayout</item>

        <!-- CometChat Color Integration -->
        <item name="cometchatPrimaryColor">@color/red_500</item>
    </style>

    <!-- Shape Appearances - Rounded Everything -->
    <style name="ShapeAppearance.Amatyma.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.Amatyma.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="ShapeAppearance.Amatyma.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Rounded Button - Social Media Style -->
    <style name="Widget.Amatyma.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="backgroundTint">@color/red_500</item>
        <item name="android:textColor">@color/white</item>
        <item name="elevation">2dp</item>
    </style>

    <!-- Rounded Button - Outlined (Secondary) -->
    <style name="Widget.Amatyma.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="strokeColor">@color/red_500</item>
        <item name="android:textColor">@color/red_500</item>
    </style>

    <!-- Rounded Card - Social Feed Style -->
    <style name="Widget.Amatyma.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">6dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">20dp</item>
        <item name="android:foreground">?android:attr/selectableItemBackground</item>
    </style>

    <!-- Rounded Input Field -->
    <style name="Widget.Amatyma.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxStrokeColor">@color/soft_gray</item>
        <item name="hintTextColor">@color/gray_600</item>
    </style>

    <!-- CometChat Specific Activities Theme -->
    <style name="Theme.Amatyma.CometChat" parent="CometChatTheme.DayNight">
        <item name="cometchatPrimaryColor">@color/red_500</item>
    </style>

    <!-- Circular ImageView Style -->
    <style name="CircularImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Rounded ImageView Style (for post images) -->
    <style name="RoundedImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Fullscreen theme for Story Viewer -->
    <style name="Theme.Amatyma.Fullscreen" parent="Theme.Amatyma">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
