<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permissions for voice/video calling -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <application
        android:name=".AmatymaApplication"
        android:allowBackup="true"
        android:allowNativeHeapPointerTagging="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Amatyma">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.Amatyma.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ProfileSetupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma.CometChat" />

        <activity
            android:name=".ConversationsActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma.CometChat" />

        <activity
            android:name=".MessagesActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma.CometChat" />

        <activity
            android:name=".DiscoverActivity"
            android:exported="false" />

        <activity
            android:name=".BusinessProfileSetupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".MyBusinessProfileActivity"
            android:exported="false" />

        <activity
            android:name=".CreatePostActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".PostDetailActivity"
            android:exported="false" />

        <activity
            android:name=".PublicBusinessProfileActivity"
            android:exported="false" />

        <activity
            android:name=".CreateStoryActivity"
            android:exported="false" />

        <activity
            android:name=".StoryViewerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Amatyma.Fullscreen" />

        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ShopActivity"
            android:exported="false" />

        <activity
            android:name=".ProductDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ProductCreateActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".EventsActivity"
            android:exported="false" />

        <activity
            android:name=".PdfViewerActivity"
            android:exported="false" />

        <activity
            android:name=".ArticlesActivity"
            android:exported="false" />

    </application>

</manifest>