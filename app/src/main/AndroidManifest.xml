<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Permissions for chat media (camera photos, voice messages) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Native VoIP call ringing via Android Telecom (ConnectionService) -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!--
        App-level theme is CometChat-compatible so UIKit call activities
        (CometChatOngoingCallActivity etc.) get the correct theme attrs.
        Non-CometChat screens override with Theme.Amatyma explicitly.
    -->
    <application
        android:name=".AmatymaApplication"
        android:allowBackup="true"
        android:allowNativeHeapPointerTagging="false"
        android:extractNativeLibs="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Amatyma.CometChat">

        <!-- ── Launcher ── -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.Amatyma.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Auth / onboarding (non-CometChat screens) ── -->
        <activity
            android:name=".AuthActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ProfileSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <!-- ── Social shell (Jetpack Compose, non-CometChat) ── -->
        <activity
            android:name=".social.HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <!-- ── CometChat screens (inherit app CometChat theme) ── -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".ConversationsActivity"
            android:exported="false" />

        <activity
            android:name=".MessagesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".UserDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".GroupDetailsActivity"
            android:exported="false" />

        <!-- ── Business / social screens (non-CometChat) ── -->
        <activity
            android:name=".DiscoverActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".BusinessProfileSetupActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".MyBusinessProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".CreatePostActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".PostDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".PublicBusinessProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".CreateStoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".StoryViewerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Amatyma.Fullscreen" />

        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ShopActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".ProductDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".ProductCreateActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".EventsActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".PdfViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <activity
            android:name=".ArticlesActivity"
            android:exported="false"
            android:theme="@style/Theme.Amatyma" />

        <service
            android:name=".AmatymaFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".MessageReplyBroadcastReceiver"
            android:exported="false" />

        <!-- ── Native VoIP calling (Android Telecom) ── -->
        <activity
            android:name=".voip.OngoingCallActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:launchMode="singleTop"
            android:excludeFromRecents="true" />

        <service
            android:name=".voip.CallConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".voip.CallEventReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="CometChat_Call_Event" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
