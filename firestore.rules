rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - users can read/write their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow list: if true;  // Allow queries for username uniqueness
      allow write: if request.auth != null && request.auth.uid == userId;

      // Follow edges: you manage your own "following" list. Counts are kept on
      // /profiles by Cloud Function triggers.
      match /following/{targetUid} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Social notifications (Alerts feed) — written by triggers, read/managed by you.
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if false;
      }

      // Post likes — your own set (doc id == postId). kudosCount on the post is
      // maintained by Cloud Function triggers.
      match /likes/{postId} {
        allow read, create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Stories seen-state — your own set (doc id == storyId).
      match /storiesSeen/{storyId} {
        allow read, create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // Followers reverse-index — written by triggers (Admin SDK); readable.
      match /followers/{followerUid} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Public profile: follower/following counts are written ONLY by triggers
    // (Admin SDK bypasses rules). The owner may edit just their social fields
    // (displayName / bio / photoURL) — never the counts.
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['displayName', 'bio', 'photoURL', 'updatedAt']);
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'bio', 'photoURL', 'updatedAt']);
    }

    // Usernames collection - allow reading for username uniqueness checks
    // Only allow writes from authenticated users for their own username
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      request.resource.data.uid == request.auth.uid;
    }

    // Businesses collection
    match /businesses/{userId} {
      allow read: if true;  // Anyone can read business profiles (for discovery)
      allow write: if request.auth != null && request.auth.uid == userId;  // Only owner can write
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;  // Anyone can read posts (for feed)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;  // Only owner can create
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;  // Only owner can edit/delete
    }

    // Stories collection
    match /stories/{storyId} {
      allow read: if true;  // Anyone can read stories (for feed and viewer)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;  // Only owner can create
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;  // Only owner can edit/delete
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;  // Anyone can read products (for shop feed)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;  // Only owner can create
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;  // Only owner can edit/delete
    }

    // Video posts (new social feed). Written only by Cloud Functions
    // (createFastpixUpload / fastpixWebhook via the Admin SDK, which bypasses
    // these rules), so clients cannot forge or tamper with posts.
    match /videoPosts/{postId} {
      allow read: if request.auth != null;  // signed-in users see the feed
      // Video posts are server-only (FastPix/Admin). Image & text posts are
      // created directly by the author, ready immediately, with zeroed counts
      // (counts are then trigger-maintained via the Admin SDK, which bypasses rules).
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.type in ['image', 'text']
                    && request.resource.data.status == 'ready'
                    && request.resource.data.kudosCount == 0
                    && request.resource.data.commentCount == 0;
      allow update, delete: if false;

      // Comments: the author creates/edits/deletes their own.
      // commentCount on the post is maintained by Cloud Function triggers.
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth != null
                      && resource.data.authorUid == request.auth.uid;

        // Threaded replies. replyCount on the parent comment is trigger-maintained.
        match /replies/{replyId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null
                        && request.resource.data.authorUid == request.auth.uid;
          allow update, delete: if request.auth != null
                        && resource.data.authorUid == request.auth.uid;
        }
      }
    }

    // Social stories (24h ephemeral). Text/image are created by the author here;
    // video stories are created server-side via the FastPix function (Admin SDK).
    match /socialStories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.type in ['text', 'image'];
      allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
