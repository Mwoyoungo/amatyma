<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <uses-feature
        android:name="android.hardware.sensor.proximity"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:name=".utils.BuilderApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/CometChat.Builder.Theme"
        android:label="@string/builder_name"
        android:localeConfig="@xml/cometchat_locale_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true">
        <activity
            android:name=".ui.activity.AIAssistantActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="screenSize|orientation|keyboardHidden"
            />
        <activity
            android:name=".ui.activity.NewChatActivity"
            android:theme="@style/CometChat.Builder.Theme"
            android:exported="false" />
        <activity
            android:name=".ui.activity.AppCredentialsActivity"
            android:theme="@style/CometChat.Builder.Theme"
            android:exported="false" />
        <activity
            android:name=".ui.activity.SplashActivity"
            android:theme="@style/CometChat.Builder.Theme"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.activity.ThreadMessageActivity"
            android:theme="@style/CometChat.Builder.Theme"
            android:configChanges="screenSize|orientation|keyboardHidden"
            android:exported="false" />
        <activity
            android:name=".ui.activity.SearchActivity"
            android:exported="false" />
        <activity
            android:theme="@style/CometChat.Builder.Theme"
            android:name=".ui.activity.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:theme="@style/CometChat.Builder.Theme"
            android:name=".ui.activity.HomeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustNothing" />
        <activity
            android:theme="@style/CometChat.Builder.Theme"
            android:name=".ui.activity.MessagesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:theme="@style/CometChat.Builder.Theme"
            android:name=".ui.activity.GroupDetailsActivity"
            android:exported="false" />
        <activity
            android:theme="@style/CometChat.Builder.Theme"
            android:name=".ui.activity.CallDetailsActivity"
            android:exported="false" />
        <activity
            android:theme="@style/CometChat.Builder.Theme"
            android:name=".ui.activity.UserDetailsActivity"
            android:exported="false" />
    </application>

</manifest>